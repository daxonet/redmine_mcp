<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= h @app_title %> – Authorize Access</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #0d0d0d;
      color: #e0e0e0;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
      padding: 24px;
    }

    .card {
      background: #1a1a1a;
      border: 1px solid #2e2e2e;
      border-radius: 16px;
      padding: 48px 40px 40px;
      width: 100%;
      max-width: 480px;
    }

    /* Icon row */
    .icons {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 12px;
      margin-bottom: 32px;
    }
    .icon-box {
      width: 56px;
      height: 56px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 22px;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: #fff;
    }
    .icon-client { background: #5a6a7a; }
    .icon-server { background: #2d7a4f; }
    .dots { color: #555; font-size: 20px; letter-spacing: 2px; }

    /* Heading */
    h1 {
      text-align: center;
      font-size: 22px;
      font-weight: 700;
      color: #f0f0f0;
      line-height: 1.35;
      margin-bottom: 24px;
    }

    /* Who is logged in */
    .who {
      background: #242424;
      border: 1px solid #333;
      border-radius: 8px;
      padding: 11px 14px;
      font-size: 13px;
      color: #aaa;
      margin-bottom: 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 8px;
    }
    .who strong { color: #e0e0e0; }
    .who a { color: #888; font-size: 12px; white-space: nowrap; text-decoration: none; }
    .who a:hover { color: #aaa; text-decoration: underline; }

    /* Permissions */
    .perms-intro {
      font-size: 14px;
      color: #aaa;
      margin-bottom: 12px;
    }
    .perms {
      list-style: disc;
      padding-left: 20px;
      margin-bottom: 24px;
      font-size: 14px;
      color: #ccc;
    }
    .perms li { margin-bottom: 6px; }

    /* Redirect notice */
    .redirect-notice {
      font-size: 13px;
      color: #777;
      margin-bottom: 28px;
      line-height: 1.5;
    }
    .redirect-notice strong { color: #aaa; word-break: break-all; }

    /* Buttons */
    .actions { display: flex; gap: 12px; }
    .btn {
      flex: 1; padding: 12px 16px;
      border-radius: 8px;
      font-size: 15px; font-weight: 600;
      cursor: pointer; border: none;
      transition: opacity .15s;
    }
    .btn:hover { opacity: .88; }
    .btn-cancel {
      background: transparent;
      border: 1px solid #444;
      color: #ccc;
    }
    .btn-authorize {
      background: #2d6be4;
      color: #fff;
    }
  </style>
</head>
<body>
  <div class="card">
    <%
      client_initial = (@client_name || 'C')[0].upcase
      app_initial    = (@app_title  || 'R')[0].upcase
    %>
    <div class="icons">
      <div class="icon-box icon-client"><%= client_initial %></div>
      <span class="dots">···</span>
      <div class="icon-box icon-server"><%= app_initial %></div>
    </div>

    <h1><%= h @client_name %> wants to access<br><%= h @app_title %></h1>

    <div class="who">
      <span>Signed in as <strong><%= h @current_user.name %></strong> (<%= h @current_user.login %>)</span>
      <%= link_to 'Switch account', signout_path(back_url: request.url) %>
    </div>

    <p class="perms-intro">
      <%= h @client_name %> will be able to access your account and perform the following actions:
    </p>
    <ul class="perms">
      <li>Read projects, issues, and time entries</li>
      <li>Create and update issues on your behalf</li>
      <li>Log time entries</li>
      <li>Search <%= h @app_title %> content</li>
    </ul>

    <p class="redirect-notice">
      You will be redirected to
      <strong><%= h @oauth[:redirect_uri] %></strong>
      after authorizing. Make sure you trust this URL.
    </p>

    <%= form_tag mcp_consent_path(params.permit(:client_id, :redirect_uri, :code_challenge,
                                                :code_challenge_method, :state, :scope)),
                 method: :post do %>
      <div class="actions">
        <%= submit_tag 'Cancel',    name: 'deny',  class: 'btn btn-cancel' %>
        <%= submit_tag 'Authorize', name: 'allow', class: 'btn btn-authorize' %>
      </div>
    <% end %>
  </div>
</body>
</html>
